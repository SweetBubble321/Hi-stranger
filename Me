<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>???</title>

<style>
body {
  margin: 0;
  background: black;
  color: #bfbfbf;
  font-family: monospace;
  overflow: hidden;
}

/* Fondo en movimiento */
.bg {
  position: fixed;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, #111 10%, black 70%);
  animation: move 10s infinite alternate;
  opacity: 0.8;
}

@keyframes move {
  from { transform: translate(-10%, -10%) scale(1); }
  to { transform: translate(-20%, -20%) scale(1.2); }
}

/* glitch */
.glitch {
  position: relative;
  font-size: 20px;
  animation: flicker 2s infinite;
}

@keyframes flicker {
  0% { opacity: 1; }
  50% { opacity: 0.3; }
  100% { opacity: 1; }
}

/* botones */
button {
  background: black;
  border: 1px solid #444;
  color: #aaa;
  padding: 10px;
  margin: 5px;
  cursor: pointer;
}

button:hover {
  color: white;
  border-color: white;
}

/* glitch visual */
.glitch-box {
  position: absolute;
  top: 30%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
  animation: shake 3s infinite;
}

@keyframes shake {
  0% { transform: translate(-50%, -50%) translateX(0); }
  20% { transform: translate(-50%, -50%) translateX(2px); }
  40% { transform: translate(-50%, -50%) translateX(-2px); }
  60% { transform: translate(-50%, -50%) translateX(1px); }
  80% { transform: translate(-50%, -50%) translateX(-1px); }
  100% { transform: translate(-50%, -50%) translateX(0); }
}

/* galería oculta */
#gallery {
  display: none;
  padding: 50px;
  text-align: center;
}

img {
  width: 200px;
  margin: 10px;
  border: 1px solid #444;
}
</style>
</head>

<body>

<div class="bg"></div>

<div class="glitch-box">
  <div class="glitch">... . -.-. .-. . - --- / ..- -. -.- -. --- .-- -.</div>
  <p>语言无法理解</p>
  <p>?? ? ?? ? ??</p>

  <button onclick="fake()">OPEN</button>
  <button onclick="fake()">ACCESS</button>
  <button onclick="fake()">ENTER</button>
  <button onclick="reveal()">▣</button>
</div>

<!-- GALERÍA OCULTA -->
<div id="gallery">
  <h1>MY ART</h1>

  <img src="https://via.placeholder.com/200" alt="art1">
  <img src="https://via.placeholder.com/200" alt="art2">
  <img src="https://via.placeholder.com/200" alt="art3">

  <p>finally found.</p>
</div>

<script>
function fake(){
  alert("...");
}

function reveal(){
  document.querySelector(".glitch-box").style.display = "none";
  document.getElementById("gallery").style.display = "block";
}
</script>

</body>
</html>
